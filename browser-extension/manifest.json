{
  "manifest_version": 3,
  "name": "Full Hangar Harvester",
  "version": "1.0.0",
  "description": "Full Hangar - Controller.com listing harvester.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "https://www.controller.com/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.controller.com/*"],
      "js": ["content_script.js"],
      "css": ["content_style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Full Hangar Harvester",
    "default_icon": {
      "16": "icon.svg",
      "32": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "16": "icon.svg",
    "32": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
