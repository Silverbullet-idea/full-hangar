# --- Stripe (buyer Deal Scout / Deal Pro subscriptions) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_SCOUT=price_...
STRIPE_PRICE_PRO=price_...

# Note: `NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY` is for future client-side Stripe.js use;
# current checkout flow is server-only via Checkout redirect.
